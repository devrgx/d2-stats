---
import "../styles/global.css";
const { title = "CruciCore — Destiny 2 PvP & Trials Tracker" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <nav class="header">
  <div class="header-left">
    <div class="brand-solid">Cruci<span>Core</span></div>
  </div>
  <div class="header-right">
    <a class="nav-link" href="/">Home</a>
    <a class="nav-link" href="/about">About</a>
    <a class="btn primary" href="https://www.bungie.net/" target="_blank" rel="noreferrer">Bungie</a>
  </div>
</nav>
      <div class="header-lightbar"></div>
      <main style="margin-top:18px;">
        <slot />
      </main>
    </div>
    <footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      © {new Date().getFullYear()} CruciCore — A Destiny 2 PvP & Trials Tracker
    </div>
    <div class="footer-right">
      <a href="/privacy" class="footer-link">Privacy</a>
      <a href="/imprint" class="footer-link">Imprint</a>
      <a href="https://github.com/ghostlinedev" target="_blank" rel="noreferrer" class="footer-link">GitHub</a>
    </div>
  </div>
</footer>
  </body>
  <script type="module">
  const header = document.querySelector('.header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 30) header?.classList.add('scrolled');
    else header?.classList.remove('scrolled');
  });
</script>
</html>
